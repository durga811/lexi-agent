# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey).
GOOGLE_API_KEY=
# Optional: override the chat model (default: gemini-3.5-flash)
# LLM_MODEL=gemini-3.5-flash

# --- Observability (optional): LangSmith tracing -----------------------------
# Get a key at https://smith.langchain.com -> Settings. When enabled, the agent,
# its LLM/tool calls, and the retrieval+rerank step (with scores) are traced.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=lexi-agent
# (the eval routes its own traces to "lexi-agent-eval" automatically)
